{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "backend"
  ],
  "scripts": {
    "dev": "concurrently --names \"frontend,backend\" -c \"bgBlue.bold,bgMagenta.bold\" \"npm start\" \"npm run dev -w @planmaster/backend\"",
    "start": "vite",
    "build": "tsc && vite build",
    "deploy": "npm run build && firebase deploy --only hosting",
    "test": "vitest"
  },
  "dependencies": {
    "@google/genai": "^0.14.0",
    "@reduxjs/toolkit": "^2.2.6",
    "firebase": "^10.12.3",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.1.2",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.5.2",
    "vite": "^5.3.3",
    "vitest": "^4.1.7"
  }
}
